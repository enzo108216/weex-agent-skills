{
  "schema_version": 3,
  "identity": {
    "name": "weex-trader-skill",
    "source_of_truth": "SKILL.md",
    "purpose": "WEEX contract and spot REST automation plus normalized analysis payloads and secure saved-profile management."
  },
  "path_policy": {
    "skill_root": ".",
    "resolve_relative_paths_from": "skill root",
    "portable_paths_only": true,
    "note": "Do not assume the workspace root is the skill root."
  },
  "read_order": {
    "default": [
      "manifest.json",
      "SKILL.md"
    ],
    "open_if_needed": {
      "file_level_details": "file-index.json",
      "skill_overview": "README.md",
      "script_operations": "references/script-operations.md",
      "trade_data_schema": "references/trade-data-schema.md",
      "auth_and_signing": "references/auth-and-signing.md",
      "profile_manager": "references/profile-manager.md",
      "profile_onboarding": "references/profile-onboarding.md",
      "linux_vault": "references/linux-vault.md",
      "troubleshooting": "references/troubleshooting.md"
    }
  },
  "routing": {
    "decision_axes": [
      "product: contract or spot",
      "request_type: market, order, profile, linux setup, or maintenance",
      "auth_scope: public or private",
      "platform: macOS/Windows or Linux",
      "interaction_mode: GUI, terminal, or headless",
      "language: zh, en, or auto"
    ],
    "domains": {
      "contract": {
        "entrypoint": "scripts/weex_contract_api.py",
        "open_first": [
          "scripts/weex_contract_api.py",
          "references/contract-api-definitions.json"
        ],
        "commands": [
          "list-endpoints",
          "call",
          "place-order",
          "cancel-order",
          "ticker",
          "poll-ticker"
        ],
        "needs_profile_for_private": true
      },
      "spot": {
        "entrypoint": "scripts/weex_spot_api.py",
        "open_first": [
          "scripts/weex_spot_api.py",
          "references/spot-api-definitions.json"
        ],
        "commands": [
          "list-endpoints",
          "call",
          "ticker",
          "place-order"
        ],
        "needs_profile_for_private": true
      },
      "trade_analysis": {
        "entrypoints": [
          "scripts/weex_trade_data_aggregator.py",
          "analysis skill replay/profile/order-risk entrypoint"
        ],
        "open_first": [
          "scripts/weex_trade_data_aggregator.py",
          "references/trade-data-schema.md"
        ]
      },
      "trade_guard": {
        "entrypoint": "scripts/weex_trade_guard.py",
        "open_first": [
          "scripts/weex_trade_guard.py",
          "scripts/weex_trade_risk_review.py",
          "scripts/weex_risk_review_core.py",
          "scripts/weex_order_intent_state.py",
          "references/trade-data-schema.md"
        ]
      },
      "profile_management": {
        "entrypoints": [
          "scripts/weex_gui_launcher.py",
          "scripts/weex_profiles_cli.py",
          "scripts/weex_profile_manager_app.py",
          "scripts/weex_vault_cli.py"
        ],
        "open_first": [
          "scripts/weex_gui_launcher.py",
          "scripts/weex_profile_store.py",
          "scripts/weex_profiles_cli.py",
          "scripts/weex_profile_manager_app.py",
          "scripts/weex_vault_cli.py"
        ]
      },
      "linux_secure_setup": {
        "entrypoints": [
          "scripts/weex_linux_profile_wizard.sh",
          "scripts/weex_vault_cli.py"
        ],
        "open_first": [
          "scripts/weex_linux_profile_wizard.sh",
          "scripts/weex_vault_cli.py"
        ]
      },
      "maintenance": {
        "entrypoint": "scripts/generate_weex_api_definitions.py",
        "open_first": [
          "scripts/weex_runtime_setup.py",
          "scripts/generate_weex_api_definitions.py"
        ],
        "writes": [
          "references/contract-api-definitions.json",
          "references/contract-api-definitions.md",
          "references/spot-api-definitions.json",
          "references/spot-api-definitions.md"
        ]
      }
    },
    "task_map": {
      "check contract balance or positions": [
        "scripts/weex_contract_api.py",
        "scripts/weex_profile_store.py"
      ],
      "check spot balance": [
        "scripts/weex_spot_api.py",
        "scripts/weex_profile_store.py"
      ],
      "replay or profile trading history": [
        "scripts/weex_trade_data_aggregator.py",
        "references/trade-data-schema.md"
      ],
      "scan current account risk": [
        "scripts/weex_trade_guard.py",
        "scripts/weex_trade_data_aggregator.py",
        "references/trade-data-schema.md"
      ],
      "preview order risk before submission": [
        "scripts/weex_trade_guard.py",
        "scripts/weex_order_intent_state.py"
      ],
      "inspect or edit saved accounts": [
        "scripts/weex_gui_launcher.py",
        "scripts/weex_profiles_cli.py",
        "scripts/weex_profile_manager_app.py",
        "scripts/weex_profile_store.py"
      ],
      "launch GUI from a tool-managed shell": [
        "scripts/weex_gui_launcher.py",
        "scripts/weex_profile_manager_app.py",
        "scripts/weex_vault_manager_app.py"
      ],
      "fix Linux secure storage": [
        "scripts/weex_linux_profile_wizard.sh",
        "scripts/weex_profile_store.py",
        "scripts/weex_vault_cli.py"
      ],
      "install private runtime dependencies": [
        "scripts/weex_runtime_setup.py",
        "references/script-operations.md"
      ],
      "inspect raw endpoint fields": [
        "references/contract-api-definitions.json",
        "references/spot-api-definitions.json"
      ]
    }
  },
  "state": {
    "profile_metadata_path": "~/.weex-trader-skill/profiles.meta.json",
    "agent_state_paths": {
      "init": "~/.weex-trader-skill/agent-init.json",
      "runtime": "~/.weex-trader-skill/agent-runtime.json"
    },
    "secure_store_backends": [
      "Application Vault"
    ],
    "env_vars": {
      "WEEX_TRADER_SKILL_HOME": "Override the runtime state directory for profiles, vault data, and agent cache.",
      "WEEX_API_TIMEOUT": "Override HTTP timeout in seconds.",
      "WEEX_ORDER_INTENT_TTL_SECONDS": "Override the pending order confirmation TTL in seconds for trade guard flows.",
      "WEEX_GUI_FORCE_FOREGROUND": "Disable GUI auto-detach and keep the GUI entrypoint attached to the current shell, which can reintroduce a Terminal/cmd window."
    }
  },
  "indexes": {
    "files": "file-index.json"
  }
}

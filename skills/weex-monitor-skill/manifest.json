{
  "schema_version": 3,
  "identity": {
    "name": "weex-monitor-skill",
    "source_of_truth": "SKILL.md",
    "purpose": "WEEX automated monitor orchestration for two scenarios: position PnL monitoring with delegated live close and symbol price TP/SL conditional close submission."
  },
  "path_policy": {
    "skill_root": ".",
    "resolve_relative_paths_from": "skill root",
    "portable_paths_only": true
  },
  "read_order": {
    "default": [
      "manifest.json",
      "SKILL.md"
    ],
    "open_if_needed": {
      "file_level_details": "file-index.json",
      "monitor_cli": "scripts/weex_monitor_cli.py",
      "live_execution_boundary": "../weex-trader-skill/SKILL.md"
    }
  },
  "routing": {
    "decision_axes": [
      "task_type: position_pnl_monitor or symbol_price_monitor",
      "trigger_source: local PnL evaluation or exchange-native price TP/SL",
      "execution_boundary: dry-run/plan-only or live execution delegated through weex-trader-skill guard commands"
    ],
    "domains": {
      "task_preview": {
        "entrypoint": "scripts/weex_monitor_cli.py",
        "commands": [
          "preview",
          "confirm-text"
        ],
        "mutating": false
      },
      "task_confirmation": {
        "entrypoint": "scripts/weex_monitor_cli.py",
        "commands": [
          "confirm"
        ],
        "mutating": "local task state only",
        "requires": [
          "--confirm-monitor"
        ]
      },
      "price_condition_planning": {
        "entrypoint": "scripts/weex_monitor_cli.py",
        "commands": [
          "build-price-order"
        ],
        "mutating": false,
        "live_execution_delegate": "weex-trader-skill"
      },
      "price_condition_submission": {
        "entrypoint": "scripts/weex_monitor_cli.py",
        "commands": [
          "submit-price-order"
        ],
        "mutating": "delegated live TP/SL order through weex-trader-skill",
        "requires": [
          "--confirm-live"
        ],
        "live_execution_delegate": "weex-trader-skill"
      },
      "pnl_evaluation": {
        "entrypoint": "scripts/weex_monitor_cli.py",
        "commands": [
          "evaluate-pnl"
        ],
        "mutating": false,
        "live_execution_delegate": "weex-trader-skill"
      },
      "pnl_live_runner": {
        "entrypoint": "scripts/weex_monitor_cli.py",
        "commands": [
          "run-live-once"
        ],
        "mutating": "delegated live market close through weex-trader-skill",
        "requires": [
          "--confirm-live"
        ],
        "live_execution_delegate": "weex-trader-skill"
      },
      "local_task_management": {
        "entrypoint": "scripts/weex_monitor_cli.py",
        "commands": [
          "list",
          "events",
          "run-once",
          "run-loop",
          "cancel"
        ],
        "mutating": "local task state only"
      }
    }
  }
}
